# Copy to .env (same dir as docker-compose.yml). Never commit the real .env.
# ntfy publisher token (write-only on logseq-* topics). See docs/ntfy-prerequisites.md.
NTFY_TOKEN=tk_replace_me
# Google Calendar "secret address in iCal format" for your vacation calendar.
# Leave empty to disable vacation gating.
VACATION_ICAL_URL=

# Parent directory holding all your Syncthing-synced Logseq graphs (each graph is a
# subfolder). Mounted read-only at /graphs. Add more graphs by dropping them here and
# adding a folder block in config.yaml — no compose change needed.
GRAPHS_ROOT=/mnt/POOL/path/to/Syncthing/Logseq

# Optional overrides:
# CONFIG_PATH=/mnt/POOL/apps/herald/config.yaml   # if not deploying from the repo checkout
# DATA_PATH=/mnt/POOL/apps/herald/data            # persistent state + iCal cache
